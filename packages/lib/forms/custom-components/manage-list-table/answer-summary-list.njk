<ul id="{{ uniqueId }}" class="manage-list-summary" data-cy="answer-list">
    {% for question in answers %}
        <li class="{% if loop.index0 >= limit %}govuk-!-display-none js-hidden-item{% endif %}" data-cy="answer-item">
            {# Joiner because we dont want it to appear on first item #}
            {% set br = joiner("<br>") %}
            
            {% for value in question %}
                {% if value.answer %}
                    {{ br() | safe }}{{ value.answer | safe }}
                {% endif %}
            {% endfor %}
        </li>
    {% endfor %}
</ul>

{% if enableToggle %}
    <br>
    <a href="#" 
       class="govuk-link govuk-link--no-visited-state js-toggle-list-btn"
       role="button" 
       draggable="false"
       aria-expanded="false" 
       aria-controls="{{ uniqueId }}"
       data-list-id="{{ uniqueId }}"
       data-cy="expand-button">
        Show more
    </a>
{% endif %}