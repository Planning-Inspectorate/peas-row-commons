{% extends "views/layouts/main.njk" %}

{% from "views/layouts/components/filter.njk" import filterComponent %}
{% from "views/layouts/components/documents-table.njk" import documentsTable %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/file-upload/macro.njk" import govukFileUpload %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/accordion/macro.njk" import govukAccordion %}

{% import "views/pagination/pagination-options.njk" as paginationOptions %}

{% set title = reference + " - Case Folder" %}

{% block pageTitle %}
    {{ title }}
{% endblock %}

{% block content %}
    {% if folderUpdates.folderUpdated %}
        {{ govukNotificationBanner({
            classes: "govuk-notification-banner__heading govuk-grid-column-two-thirds",
            text: "Folder has been updated",
            type: "success",
            attributes: { "data-cy": "notification-folder-updated" }
        }) }}
    {% endif %}
    {% if folderUpdates.folderCreated %}
        {{ govukNotificationBanner({
            classes: "govuk-notification-banner__heading govuk-grid-column-two-thirds",
            text: "Folder created",
            type: "success",
            attributes: { "data-cy": "notification-folder-created" }
        }) }}
    {% endif %}
    {% if folderUpdates.filesMoved %}
        {{ govukNotificationBanner({
            classes: "govuk-notification-banner__heading govuk-grid-column-two-thirds",
            text: "Selected file(s) moved to " + folderName + " folder",
            type: "success",
            attributes: { "data-cy": "notification-files-moved" }
        }) }}
    {% endif %}
    {% if folderUpdates.folderDeleted %}
        {{ govukNotificationBanner({
            classes: "govuk-notification-banner__heading govuk-grid-column-two-thirds",
            text: "Folder deleted",
            type: "success"
        }) }}
    {% endif %}
    {% if folderUpdates.folderRenamed %}
        {{ govukNotificationBanner({
            classes: "govuk-notification-banner__heading govuk-grid-column-two-thirds",
            text: "Folder renamed",
            type: "success"
        }) }}
    {% endif %}
    {% if folderUpdates.filesDeleted %}
        {{ govukNotificationBanner({
            classes: "govuk-notification-banner__heading govuk-grid-column-two-thirds",
            text: "Selected file(s) deleted",
            type: "success"
        }) }}
    {% endif %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-full govuk-!-margin-bottom-3">
            <h2 class="govuk-caption-l" data-cy="case-reference">
                {{ reference }}
            </h2>
            <h1 class="govuk-heading-l" data-cy="page-heading">
                {{ pageHeading }}
            </h1>
            <h1 class="govuk-heading-m" data-cy="folder-name-heading">
                {{ folderName }} folder
            </h1>
        </div>
    </div>
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-full govuk-button-group">
            {{ govukButton({
                text: "Create subfolder",
                href: currentPath + "/create-folder",
                classes: "govuk-button--secondary",
                attributes: { "data-cy": "create-subfolder-btn" }
            }) }}

            {{ govukButton({
                text: "Rename folder",
                href: currentPath + "/rename-folder",
                classes: "govuk-button--secondary"
            }) }}

            {{ govukButton({
                text: "Delete folder",
                href: currentPath + "/delete-folder",
                classes: "govuk-button--secondary"
            }) }}
        </div>
    </div>
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
            {% if subFolders|length !== 0 %}
                {% set subFoldersHtml %}
                    <div class="pins-link-menu">
                        {% for folder in subFolders %}
                            <a class="govuk-link govuk-heading-s" href="{{ baseFoldersUrl }}/{{ folder.id }}/{{ folder.encodedDisplayName }}" data-cy="subfolder-link-{{ folder.id }}">
                                {{ folder.displayName }}
                            </a>
                        {% endfor %}
                    </div>
                {% endset %}

                {{ govukAccordion({
                    id: "sub-folders-accordion",
                    classes: "hide-controls",
                    hideAllSections: true,
                    showSectionText: "Show subfolders list",
                    hideSectionText: "Hide subfolders list",
                    items: [
                        {
                            content: {
                                html: subFoldersHtml
                            }
                        }
                    ],
                    attributes: { "data-cy": "subfolders-accordion" }
                }) }}
            {% endif %}
        </div>
    </div>

    <div class="govuk-grid-row">
        <div class="case-folder-filter-column govuk-grid-column-two-thirds">
            <form method="GET" action="{{ currentPath }}">
                {{ filterComponent(
                    filterData.checkboxGroups,
                    filterData.selectedCategories
                ) }}
            </form>
        </div>
        
        <div class="case-folder-table-column govuk-grid-column-two-thirds">
            <div id="pagination" class="govuk-body">
                <div class="govuk-grid-row">
                    <div class="govuk-grid-column-full">
                        
                        <form action="{{ currentPath }}/move-files" method="POST">
                            {% if _csrf %}<input type="hidden" name="_csrf" value="{{ _csrf }}">{% endif %}

                            <input type="hidden" name="returnUrl" value="{{ currentUrl }}">
                            <input type="hidden" name="caseId" value="{{ caseId }}">

                            <p class="govuk-body govuk-!-font-weight-bold">File actions</p>

                            <div class="govuk-!-margin-bottom-4">
                                    <span class="govuk-body govuk-!-margin-bottom-0">
                                        This folder contains {{ paginationParams.totalDocuments | default(0) }} file(s).
                                    </span>
                                
                                {% if documents|length !== 0 %}
                                    <span class="govuk-body govuk-!-margin-bottom-0" data-cy="pagination-results-text">
                                        Showing <strong>{{ paginationParams.resultsStartNumber }}</strong> to <strong>{{ paginationParams.resultsEndNumber if paginationParams.totalFilteredDocuments > paginationParams.resultsEndNumber else paginationParams.totalFilteredDocuments }}</strong>
                                        of <strong>{{ paginationParams.totalFilteredDocuments }}</strong> files.
                                    </span>
                                {% endif %}
                            </div>

                            {% if documents|length !== 0 %}
                                <div class="pins-pagination-options govuk-!-margin-bottom-4">
                                    {{ paginationOptions.renderPagination(paginationParams.selectedItemsPerPage, paginationParams.totalFilteredDocuments, paginationParams.pageNumber, paginationParams.searchValue, paginationParams.filtersValue) }}
                                </div>
                            {% endif %}
                            <div class="govuk-button-group govuk-!-margin-bottom-4">
                                {{ govukButton({
                                    text: "Upload files",
                                    href: currentPath + "/upload",
                                    classes: "govuk-button--secondary",
                                    attributes: { "data-cy": "upload-files-btn" }
                                }) }}

                                {% if documents|length !== 0 %}
                                    {{ govukButton({
                                        text: "Move selected",
                                        classes: "govuk-button--secondary",
                                        attributes: { 
                                            "data-module": "govuk-button",
                                            "data-cy": "move-selected-btn" 
                                        }
                                    }) }}

                                    {{ govukButton({
                                        text: "Download selected",
                                        classes: "govuk-button--secondary",
                                        attributes: { 
                                            "data-module": "govuk-button",
                                            "data-cy": "download-selected-btn",
                                            "formaction": "/documents/download"
                                        }
                                    }) }}

                                    {{ govukButton({
                                        text: "Delete selected",
                                        classes: "govuk-button--secondary",
                                        attributes: { 
                                            "data-module": "govuk-button",
                                            "data-cy": "delete-selected-btn",
                                            "formaction": currentPath + "/documents/delete-confirmation"
                                        }
                                    }) }}
                                {% endif %}
                            </div>

                            {% if documents|length !== 0 %}
                                <!-- Polite aria so that screen readers will gently let the user know when this number changes -->
                                <p id="selection-count-container" class="govuk-body govuk-!-display-none" aria-live="polite">
                                    <span id="selection-count-number">0</span> file(s) selected
                                </p>
                                <p class="govuk-body">Select 'All' checkbox to select all the files.</p>
                                <div class="govuk-grid-row">
                                    <div class="govuk-grid-column-full">
                                        {{ documentsTable(documents, currentPath, true, false) }}
                                    </div>
                                </div>
                                {# if uiItems.items is <=1 then pagination options not shown #} 
                                {% if paginationParams.uiItems.items.length > 1 %}
                                    {{ govukPagination(paginationParams.uiItems) }}
                                {% endif %}
                           {% else %}
                                {% if filterData.selectedCategories.categories | length > 0 %}
                                    <p class="govuk-body govuk-!-margin-top-4">
                                        No files match your selected filters.
                                        Try <a href="{{ currentPath }}" class="govuk-link govuk-link--no-visited-state">clearing your filters</a>.
                                    </p>
                                {% endif %}
                            {% endif %}
                        </form>
                        {# This is the target form for inline status changes, which is needed independent of the main form to avoid it picking up the checkboxes #}
                        <form id="inline-action-form" action="/documents/toggle-action" method="POST" style="display: none;">
                            <input type="hidden" name="caseId" value="{{ caseId }}">
                            <input type="hidden" name="returnUrl" value="{{ currentUrl }}">
                            {% if _csrf %}<input type="hidden" name="_csrf" value="{{ _csrf }}">{% endif %}
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
<script type="module" {% if cspNonce %}nonce="{{ cspNonce }}"{% endif %}>
        document.addEventListener('DOMContentLoaded', function() {
            const selectAll = document.getElementById('checkboxes-all');
            const checkboxes = document.querySelectorAll('input[name="selectedFiles"]');
            const countContainer = document.getElementById('selection-count-container');
            const countNumber = document.getElementById('selection-count-number');

            if (countContainer && checkboxes.length > 0) {
                countContainer.classList.remove('govuk-!-display-none');
            }

            function updateCount() {
                const selectedCount = document.querySelectorAll('input[name="selectedFiles"]:checked').length;
                if (countNumber) {
                    countNumber.textContent = selectedCount;
                }
            }

            updateCount();

            if (selectAll) {
                selectAll.addEventListener('change', function(e) {
                    checkboxes.forEach(function(cb) {
                        cb.checked = e.target.checked;
                    });
                    updateCount();
                });

                checkboxes.forEach(function(cb) {
                    cb.addEventListener('change', function() {
                        const allChecked = Array.from(checkboxes).every(c => c.checked);
                        selectAll.checked = allChecked;
                        updateCount();
                    });
                });
            }
        });
    </script>
{% endblock %}
