{#
    Contact List PDF

    Renders all contacts (excluding objectors and applicants/appellants)
    for a case in a table format for offline use.
#}
{% extends "views/cases/case-download/views/pdf-base.njk" %}

{% block title %}Contact list{% endblock %}

{% block content %}

    <h1>Contact list</h1>

    <table class="details-grid" style="margin-bottom: 20px;">
        <tr>
            <th>Case reference</th>
            <td>{{ reference }}</td>
        </tr>
        <tr>
            <th>Case name</th>
            <td>{{ caseName }}</td>
        </tr>
        <tr>
            <th>Total contacts</th>
            <td>{{ contacts.length }}</td>
        </tr>
    </table>

    {% if contacts.length > 0 %}
        {% for contact in contacts %}
            <hr class="section-break">
            <div class="avoid-break" style="margin-bottom: 16px;">
                <h3>Contact {{ loop.index }}</h3>
                <table class="details-grid">
                    <tr>
                        <th>Type</th>
                        <td>{{ contact.contactType | fallback('-') }}</td>
                    </tr>
                    <tr>
                        <th>Name</th>
                        <td>{{ contact.firstName | fallback('') }} {{ contact.lastName | fallback('') }}</td>
                    </tr>
                    <tr>
                        <th>Joint contacts or company name</th>
                        <td>{{ contact.orgName | fallback('-') }}</td>
                    </tr>
                    <tr>
                        <th>Email</th>
                        <td>{{ contact.email | fallback('-') }}</td>
                    </tr>
                    <tr>
                        <th>Telephone</th>
                        <td>{{ contact.telephoneNumber | fallback('-') }}</td>
                    </tr>
                    <tr>
                        <th>Address</th>
                        <td class="address-block">
                            {% if contact.address %}
                                {% if contact.address.addressLine1 %}{{ contact.address.addressLine1 }}<br>{% endif %}
                                {% if contact.address.addressLine2 %}{{ contact.address.addressLine2 }}<br>{% endif %}
                                {% if contact.address.townCity %}{{ contact.address.townCity }}<br>{% endif %}
                                {% if contact.address.county %}{{ contact.address.county }}<br>{% endif %}
                                {% if contact.address.postcode %}{{ contact.address.postcode }}{% endif %}
                            {% else %}
                                -
                            {% endif %}
                        </td>
                    </tr>
                </table>
            </div>
        {% endfor %}
    {% else %}
        <p class="empty-state">No contacts recorded for this case.</p>
    {% endif %}

{% endblock %}
