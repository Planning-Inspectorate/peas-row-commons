{#
    Objector List PDF

    Renders all objectors for a case in a table format for offline use.
    Each objector shows name, organisation, contact details, and status.
#}
{% extends "views/cases/case-download/views/pdf-base.njk" %}

{% block title %}Objector list{% endblock %}

{% block content %}

    <h1>Objector list</h1>

    <table class="details-grid" style="margin-bottom: 20px;">
        <tr>
            <th>Case reference</th>
            <td>{{ reference }}</td>
        </tr>
        <tr>
            <th>Case name</th>
            <td>{{ caseName }}</td>
        </tr>
        <tr>
            <th>Total objectors</th>
            <td>{{ objectors.length }}</td>
        </tr>
    </table>

    {% if objectors.length > 0 %}
        {% for objector in objectors %}
            <hr class="section-break">
            <div class="avoid-break" style="margin-bottom: 16px;">
                <h3>Objector {{ loop.index }}</h3>
                <table class="details-grid">
                    <tr>
                        <th>Name</th>
                        <td>{{ objector.firstName | fallback('') }} {{ objector.lastName | fallback('') }}</td>
                    </tr>
                    <tr>
                        <th>Joint objectors or company name</th>
                        <td>{{ objector.orgName | fallback('-') }}</td>
                    </tr>
                    <tr>
                        <th>Email</th>
                        <td>{{ objector.email | fallback('-') }}</td>
                    </tr>
                    <tr>
                        <th>Telephone</th>
                        <td>{{ objector.telephoneNumber | fallback('-') }}</td>
                    </tr>
                    <tr>
                        <th>Status</th>
                        <td>{{ objector.status | fallback('-') }}</td>
                    </tr>
                    <tr>
                        <th>Address</th>
                        <td class="address-block">
                            {% if objector.address %}
                                {% if objector.address.addressLine1 %}{{ objector.address.addressLine1 }}<br>{% endif %}
                                {% if objector.address.addressLine2 %}{{ objector.address.addressLine2 }}<br>{% endif %}
                                {% if objector.address.townCity %}{{ objector.address.townCity }}<br>{% endif %}
                                {% if objector.address.county %}{{ objector.address.county }}<br>{% endif %}
                                {% if objector.address.postcode %}{{ objector.address.postcode }}{% endif %}
                            {% else %}
                                -
                            {% endif %}
                        </td>
                    </tr>
                </table>
            </div>
        {% endfor %}
    {% else %}
        <p class="empty-state">No objectors recorded for this case.</p>
    {% endif %}

{% endblock %}
