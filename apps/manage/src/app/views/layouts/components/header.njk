{% from "govuk/components/service-navigation/macro.njk" import govukServiceNavigation %}
{% from "ui/header/pins-header.njk" import pinsHeader %}

{% macro header(serviceName, currentPage) %}
    {{ pinsHeader({isExternal: false}) }}

    {{ govukServiceNavigation({
        serviceName: serviceName,
        serviceUrl: "/",
        classes: 'pins-service-navigation',
        navigation: [
            {
                href: "/cases/personal-list",
                text: "Assigned to me",
                active: currentPage === 'personal-list'
            },
            {
                href: "/cases",
                text: "All cases",
                active: currentPage === 'all-cases'
            },
            {
                href: "/cases/create-a-case",
                text: "Create a case",
                active: currentPage === 'create-a-case'
            },
            {
                href: "/auth/signout",
                text: "Sign out"
            }
        ]
    }) }}
{% endmacro %}
