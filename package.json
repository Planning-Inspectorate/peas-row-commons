{
  "name": "peas-row-commons",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.21.0"
  },
  "scripts": {
    "check-types": "npx tsc",
    "commitlint": "commitlint --from=$(git rev-parse $(git cherry origin/main | head -n 1 | cut -c 3-)^1)",
    "db-migrate-dev": "npm run migrate-dev --workspace @pins/peas-row-commons-database",
    "db-migrate-prod": "npm run migrate-prod --workspace @pins/peas-row-commons-database",
    "db-generate": "npm run generate --workspace @pins/peas-row-commons-database",
    "db-seed": "npm run seed --workspace @pins/peas-row-commons-database",
    "db-seed-prod": "npm run seed-prod --workspace @pins/peas-row-commons-database",
    "format": "npm run format:prettier && npm run format:css",
    "format:prettier": "prettier --write .",
    "format:css": "stylelint \"**/*.{css,scss}\" --fix",
    "format-check": "prettier --check .",
    "lint": "npm run lint:ts && npm run lint:css",
    "lint:ts": "npx eslint .",
    "lint:css": "stylelint \"**/*.{css,scss}\"",
    "prepare": "node .husky/install.mjs",
    "test": "node --test",
    "test-coverage": "node --test --experimental-test-coverage",
    "cypress": "tsx cypress/scripts/cypress-runner.ts",
    "cypress:open": "cypress open",
    "cypress:smoke": "cypress run --env journeyTags=smoke",
    "cypress:regression": "cypress run --env journeyTags=regression"
  },
  "dependencies": {
    "@azure/functions": "^4.14.0",
    "@azure/identity": "^4.13.1",
    "@azure/msal-node": "^5.1.5",
    "@azure/storage-blob": "^12.31.0",
    "@ministryofjustice/frontend": "^9.0.0",
    "@planning-inspectorate/dynamic-forms": "^3.8.3",
    "@prisma/adapter-mssql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "accessible-autocomplete": "^3.0.1",
    "archiver": "^7.0.1",
    "body-parser": "^2.2.2",
    "cfb": "^1.2.2",
    "connect-redis": "^9.0.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "eslint-plugin-check-file": "^3.3.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.0",
    "file-type": "^21.3.4",
    "govuk-frontend": "^6.1.0",
    "helmet": "^8.1.0",
    "multer": "^2.2.0",
    "nunjucks": "^3.2.4",
    "pdf-lib": "^1.17.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "puppeteer": "^24.40.0",
    "redis": "^5.8.3",
    "stylelint": "^17.13.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@faker-js/faker": "^10.3.0",
    "@microsoft/microsoft-graph-types": "^2.43.1",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/nunjucks": "^3.2.6",
    "@types/prompts": "^2.4.9",
    "adm-zip": "^0.5.17",
    "cookie-parser": "^1.4.7",
    "cypress": "^15.15.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "playwright-core": "^1.58.2",
    "prettier": "^3.8.3",
    "prettier-plugin-prisma": "^5.0.0",
    "prisma": "^7.8.0",
    "prompts": "^2.4.2",
    "sass": "^1.93.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix"
    ],
    "*.{css,scss}": [
      "stylelint --fix"
    ],
    "*.{js,ts,json,md,prisma,yml,yaml,scss}": [
      "prettier --write"
    ]
  }
}
